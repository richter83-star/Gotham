# ==========================================
# CaseGraph OS Environment Configuration
# ==========================================
# Rename this file to `.env` and fill out the values below.

# ------------------------------------------
# 1. Backend Core (FastAPI / Celery)
# ------------------------------------------

# Environment (development, staging, production)
ENVIRONMENT=production

# The Secret Key used for signing JWT Authentication tokens. 
# Generate a secure key using: `openssl rand -hex 32`
SECRET_KEY=your-super-secret-jwt-signing-key-goes-here

# ------------------------------------------
# 2. Database & Broker Connections
# ------------------------------------------

# PostgreSQL Connection String
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/casegraph

# Redis Connection String (Used for Celery Queues and Caching)
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------
# 3. Artificial Intelligence / LLM
# ------------------------------------------

# OpenAI API Key (Required for Entity Extraction, Next Best Action, and Summarization)
OPENAI_API_KEY=sk-your-openai-api-key-here

# (Optional) Anthropic Claude API Key (If swapping out OpenAI)
# ANTHROPIC_API_KEY=sk-ant-your-claude-key-here

# ------------------------------------------
# 4. Frontend Application (Next.js)
# ------------------------------------------

# The URL where your Next.js frontend can reach your FastAPI backend.
# IMPORTANT: For VPS deployment, replace 'localhost' with your VPS IP or domain (e.g., http://1.2.3.4:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mapbox Access Token (Required for the Geospatial Intelligence / Sprint 6 Mapping features)
# Get a free token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-gl-access-token-here
